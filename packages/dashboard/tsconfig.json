{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    // Keep previous dist output when TypeScript has errors.
    "noEmitOnError": true
  },
  "include": ["src"]
}
