{
  "name": "@devness/useai-dashboard",
  "version": "1.0.0",
  "type": "module",
  "files": ["dist", "src", "package.json"],
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./components/insights/*": "./src/components/insights/*.tsx",
    "./components/sessions/*": "./src/components/sessions/*.tsx",
    "./components/stats/*": "./src/components/stats/*.tsx",
    "./components/time-travel/*": "./src/components/time-travel/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./constants/frameworks": "./src/constants/frameworks.ts",
    "./store": "./src/store.ts"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@devness/useai-types": "workspace:*",
    "lucide-react": "^0.475.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
