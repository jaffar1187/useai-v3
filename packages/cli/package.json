    "@devness/useai-cloud": "workspace:*",
    "@devness/useai-daemon": "workspace:*",
    "commander": "^12.0.0",
    "picocolors": "^1.1.0",
    "@clack/prompts": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0"
  }
}
