{
  "name": "@devness/useai-cli",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "files": ["dist"],
  "bin": {
    "useai": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
